# Track large binary and data files with Git LFS to keep clone size manageable.
# See https://git-lfs.com for setup instructions.
#
# Without LFS these files bloat the repo and cause checkout failures on
# macOS (APFS filename limits) and some Linux distros (see issue #1).

# Databases
*.bin filter=lfs diff=lfs merge=lfs -text
*.sqlite3 filter=lfs diff=lfs merge=lfs -text
*.db filter=lfs diff=lfs merge=lfs -text

# Large data files
*.jsonl filter=lfs diff=lfs merge=lfs -text
skills/trialgpt-matching/repo/dataset/**/*.json filter=lfs diff=lfs merge=lfs -text
skills/genome-compare/data/*.gz filter=lfs diff=lfs merge=lfs -text
